# mock 表示不调用真实模型，只使用本地规则生成结果。
MODEL_PROVIDER=mock

# 当 MODEL_PROVIDER 不为 mock 时，可以填 OpenAI 兼容接口地址。
# 例如 OpenAI: https://api.openai.com/v1
# 例如 DeepSeek: https://api.deepseek.com/v1
MODEL_BASE_URL=https://api.openai.com/v1

# 真实模型 API Key。未配置时会自动回退到 mock。
MODEL_API_KEY=

# 模型名按你的平台填写。
MODEL_NAME=gpt-4.1-mini

# 传输协议。chat_completions 适合多数 OpenAI 兼容网关；
# responses 适合和 Codex 当前配置一致的 provider。
MODEL_WIRE_API=chat_completions

# 推理强度，主要用于 responses API。
MODEL_REASONING_EFFORT=medium

# 某些网关只支持流式返回。
MODEL_STREAM=false

# 请求超时和温度参数。
MODEL_TIMEOUT_SECONDS=8
MODEL_TEMPERATURE=0.4

# 可选：统一系统提示词。
MODEL_SYSTEM_PROMPT=你是零售 CRM 场景下的导购任务 Agent 助手，输出简洁、可信、可执行的中文内容。

# 商业化导购工作台默认策略。
CRM_DEFAULT_RESULT_COUNT=4
CRM_MAX_RESULT_COUNT=8
CRM_CUSTOMER_SAMPLE_LIMIT=4
CRM_RELATIONSHIP_PRODUCT_LIMIT=3
CRM_WORKFLOW_NOTE_LIMIT=4
CRM_MEMORY_BRIEF_LIMIT=4

# 快捷提示可用 || 或换行分隔。
CRM_QUICK_PROMPTS=帮我找今天该优先跟进但还没联系的高净值客户||给偏好通勤西装的客户挑 3 款本周有货的单品||把今天到期还没完成的回访任务按优先级排一下
